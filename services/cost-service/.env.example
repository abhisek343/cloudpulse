# Application
APP_NAME=CloudPulse AI - Cost Service
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:3005"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:cloudpulse-dev-password@db:5432/cloudpulse

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://cloudpulse:cloudpulse-dev-password@rabbitmq:5672/

# AWS (optional - can use IAM roles in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SESSION_TOKEN=
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GCP_PROJECT_ID=
GCP_BILLING_ACCOUNT_ID=
GCP_SERVICE_ACCOUNT_JSON=
GCP_SERVICE_ACCOUNT_FILE=
GCP_BILLING_EXPORT_TABLE=
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL=openrouter/free
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TIMEOUT_SECONDS=60
LLM_FALLBACK_MODELS=["stepfun/step-3.5-flash:free","nvidia/nemotron-3-super-120b-a12b-20230311:free"]

# JWT
JWT_SECRET_KEY=cloudpulse-dev-shared-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=cloudpulse_refresh_token
CSRF_COOKIE_NAME=cloudpulse_csrf_token
AUTH_COOKIE_SECURE=false
ACCOUNT_CREDENTIALS_KEY=
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cloudpulse-cost-service
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SAMPLER_RATIO=1.0

# Safe local default: simulate billing data instead of calling real cloud APIs
CLOUD_SYNC_MODE=demo
ALLOW_LIVE_CLOUD_SYNC=false
DEFAULT_DEMO_SCENARIO=saas
DEFAULT_DEMO_SEED=42
DEFAULT_DEMO_PROVIDER=aws
